export DOCKER_CLI_EXPERIMENTAL=enabled

#
# Paths
#
export GOPATH=$HOME/go

export PATH="$HOME/bin:$HOME/.local/bin:$PATH"
export PATH="$HOME/.symfony/bin:$PATH"
export PATH="$PATH:/usr/local/go/bin:$GOPATH/bin"
export PATH="$ANDROID_SDK_ROOT/emulator:$ANDROID_SDK_ROOT/tools:$ANDROID_SDK_ROOT/tools/bin:$ANDROID_SDK_ROOT/platform-tools:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

#
# Other
export TERM='xterm'
export AGENT_BROWSER_IGNORE_HTTPS_ERRORS=true
export PLAYWRIGHT_IGNORE_HTTPS_ERRORS=true
export ANDROID_SDK_ROOT=$HOME/Android/Sdk
export HOSTFILE=$HOME/.hosts    # Put a list of remote hosts in ~/.hosts
export JAVA_HOME=/usr/lib/jvm/jdk-21.0.8-oracle-x64

#
# History
#
export HISTIGNORE="&:bg:fg:ll:h"
export HISTTIMEFORMAT="$(echo -e ${BCyan})[%d/%m %H:%M:%S]$(echo -e ${NC}) "
export HISTCONTROL=ignoreboth
export HISTSIZE=100000
export HISTFILESIZE=100000
export TIMEFORMAT=$'\nreal %3R\tuser %3U\tsys %3S\tpcpu %P\n'
export EDITOR=nano
