	defer <<<"mkdir -p /var/lib/fprint/.broadcomCv3plusFW"
	defer <<<"cd /opt/fprint-broadcom/brcm_linux_fp && sh install.sh"
	defer <<<"rm -rf /opt/fprint-broadcom /usr/local/bin/fprint-broadcom"
	defer <<<"udevadm control --reload-rules && udevadm trigger"
	defer <<<"systemctl restart fprintd"
}

