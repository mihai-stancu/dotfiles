dotfiles() {
	guard --file .bash_aliases

	defer <<-SH
		[[ -d /home/$USER/Dropbox/etc ]] || exit 0

		for src in /home/$USER/Dropbox/etc/.* /home/$USER/Dropbox/etc/[A-Z]*; do
			[[ -e "\$src" ]] || continue
			name=\$(basename "\$src")
			[[ "\$name" == ".config" ]] && continue
			ln -sf "\$src" /home/$USER/"\$name"
		done

		mkdir -p /home/$USER/.config
		for src in /home/$USER/Dropbox/etc/.config/*; do
			[[ -e "\$src" ]] || continue
			ln -sf "\$src" /home/$USER/.config/\$(basename "\$src")
		done

		# Disable display dimming
		GS="sudo -u $USER DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/\$(id -u $USER)/bus gsettings"
		\$GS set org.gnome.settings-daemon.plugins.power ambient-enabled false
		\$GS set org.gnome.settings-daemon.plugins.power idle-dim false
		\$GS set org.gnome.desktop.screensaver idle-activation-enabled false
		\$GS set org.gnome.desktop.screensaver lock-enabled false
		sudo -u $USER xset s off
		sudo -u $USER xset -dpms
		sudo -u $USER xset s noblank
	SH
}

