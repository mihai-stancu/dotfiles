flameshot() {
	guard flameshot

	apt flameshot
	apt libglib2.0-bin
	defer <<-SH
		GS="sudo -u $USER DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/\$(id -u $USER)/bus gsettings"

		# Disable GNOME's built-in screenshot UI on PrintScreen
		\$GS set org.gnome.shell.keybindings show-screenshot-ui '[]'

		# Register custom keybinding slot
		KEYBINDINGS=\$(\$GS get org.gnome.settings-daemon.plugins.media-keys custom-keybindings)
		if [[ "\$KEYBINDINGS" != *"flameshot"* ]]; then
			KEYBINDINGS=\$(echo "\$KEYBINDINGS" | sed "s|]|, '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/flameshot/']|; s|\[, |[|")
			\$GS set org.gnome.settings-daemon.plugins.media-keys custom-keybindings "\$KEYBINDINGS"
		fi

		# Bind PrintScreen to flameshot gui (area selection)
		\$GS set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/flameshot/ name 'Flameshot Screenshot'
		\$GS set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/flameshot/ command 'flameshot gui'
		\$GS set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/flameshot/ binding 'Print'
	SH
}

fprintd() {
